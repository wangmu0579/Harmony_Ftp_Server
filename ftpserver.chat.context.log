                "command": "python3 << 'PYEOF'\nfrom PIL import Image, ImageDraw, ImageFont\nimport math\n\ndef create_ftp_icon(size, output_path):\n    img = Image.new('RGBA', (size, size), (0, 0, 0, 0))\n    draw = ImageDraw.Draw(img)\n    \n    s = size\n    cx, cy = s // 2, s // 2\n    \n    # 圆形背景 - 渐变蓝色\n    for r in range(s // 2, 0, -1):\n        ratio = r / (s // 2)\n        # 从深蓝到亮蓝的渐变\n        red = int(30 + (50 - 30) * (1 - ratio))\n        green = int(100 + (150 - 100) * (1 - ratio))\n        blue = int(200 + (255 - 200) * (1 - ratio))\n        draw.ellipse([cx - r, cy - r, cx + r, cy + r], fill=(red, green, blue, 255))\n    \n    # 服务器图标 - 两个堆叠的矩形（代表服务器）\n    box_w = int(s * 0.44)\n    box_h = int(s * 0.14)\n    box_x = cx - box_w // 2\n    box_y1 = int(cy - s * 0.18)\n    box_y2 = box_y1 + box_h + int(s * 0.04)\n    radius = int(s * 0.03)\n    \n    # 上面的服务器盒子\n    draw.rounded_rectangle([box_x, box_y1, box_x + box_w, box_y1 + box_h], \n                           radius=radius, fill=(255, 255, 255, 230))\n    # 服务器指示灯\n    dot_r = int(s * 0.02)\n    dot_y = box_y1 + box_h // 2\n    draw.ellipse([box_x + int(s*0.06) - dot_r, dot_y - dot_r, \n                  box_x + int(s*0.06) + dot_r, dot_y + dot_r], fill=(80, 200, 120, 255))\n    draw.ellipse([box_x + int(s*0.12) - dot_r, dot_y - dot_r, \n                  box_x + int(s*0.12) + dot_r, dot_y + dot_r], fill=(80, 200, 120, 255))\n    # 服务器线条\n    line_y = dot_y\n    draw.line([box_x + int(s*0.18), line_y, box_x + box_w - int(s*0.04), line_y], \n              fill=(180, 200, 220, 200), width=max(1, int(s*0.01)))\n    \n    # 下面的服务器盒子\n    draw.rounded_rectangle([box_x, box_y2, box_x + box_w, box_y2 + box_h], \n                           radius=radius, fill=(255, 255, 255, 230))\n    dot_y2 = box_y2 + box_h // 2\n    draw.ellipse([box_x + int(s*0.06) - dot_r, dot_y2 - dot_r, \n                  box_x + int(s*0.06) + dot_r, dot_y2 + dot_r], fill=(80, 200, 120, 255))\n    draw.ellipse([box_x + int(s*0.12) - dot_r, dot_y2 - dot_r, \n                  box_x + int(s*0.12) + dot_r, dot_y2 + dot_r], fill=(80, 200, 120, 255))\n    draw.line([box_x + int(s*0.18), dot_y2, box_x + box_w - int(s*0.04), dot_y2], \n              fill=(180, 200, 220, 200), width=max(1, int(s*0.01)))\n    \n    # 上下箭头（代表文件传输）\n    arrow_x = cx\n    arrow_top = box_y2 + box_h + int(s * 0.06)\n    arrow_bot = arrow_top + int(s * 0.16)\n    arrow_w = int(s * 0.05)\n    lw = max(2, int(s * 0.025))\n    \n    # 上箭头（上传）\n    ax1 = cx - int(s * 0.08)\n    draw.line([ax1, arrow_bot, ax1, arrow_top], fill=(255, 255, 255, 220), width=lw)\n    draw.polygon([(ax1, arrow_top - int(s*0.02)), \n                  (ax1 - arrow_w, arrow_top + int(s*0.04)),\n                  (ax1 + arrow_w, arrow_top + int(s*0.04))], fill=(255, 255, 255, 220))\n    \n    # 下箭头（下载）\n    ax2 = cx + int(s * 0.08)\n    draw.line([ax2, arrow_top, ax2, arrow_bot], fill=(255, 255, 255, 220), width=lw)\n    draw.polygon([(ax2, arrow_bot + int(s*0.02)), \n                  (ax2 - arrow_w, arrow_bot - int(s*0.04)),\n                  (ax2 + arrow_w, arrow_bot - int(s*0.04))], fill=(255, 255, 255, 220))\n    \n    # FTP 文字\n    try:\n        font = ImageFont.truetype(\"/System/Library/Fonts/Helvetica.ttc\", int(s * 0.11))\n    except:\n        font = ImageFont.load_default()\n    \n    text = \"FTP\"\n    bbox = draw.textbbox((0, 0), text, font=font)\n    tw = bbox[2] - bbox[0]\n    text_y = arrow_bot + int(s * 0.04)\n    draw.text((cx - tw // 2, text_y), text, fill=(255, 255, 255, 240), font=font)\n    \n    img.save(output_path, 'PNG')\n\nbase = \"/Users/wangmu0579/DevEcoStudioProjects/ftpServer\"\n\n# foreground 图标 (1024x1024 用于 layered_image)\ncreate_ftp_icon(1024, f\"{base}/AppScope/resources/base/media/foreground.png\")\ncreate_ftp_icon(1024, f\"{base}/entry/src/main/resources/base/media/foreground.png\")\n\n# app_icon (用于某些场景)\ncreate_ftp_icon(512, f\"{base}/AppScope/resources/base/media/app_icon.png\")\n\n# startIcon\ncreate_ftp_icon(256, f\"{base}/entry/src/main/resources/base/media/startIcon.png\")\n\nprint(\"Icons generated successfully\")\nPYEOF",
