                "tool_use_id": "tooluse_blVWnwI0nXMbNRLLRK1jIh",
                "content": [
                  {
                    "Text": "=== Operation 1 Result (Text) ===\nimport socket from '@ohos.net.socket';\nimport { FtpConnection, Address, DataServer } from './FtpConnection';\nimport { FtpConfig } from './FtpConfig';\nimport { FtpLogger } from './FtpLogger';\n\nexport interface ServerStatus {\n  isRunning: boolean;\n  port: number;\n  connectionCount: number;\n}\n\nexport class FtpServer {\n  private serverSocket: DataServer | null = null;\n  private connections: FtpConnection[] = [];\n  private config: FtpConfig;\n  private logger: FtpLogger;\n  private isRunning: boolean = false;\n\n  constructor(config: FtpConfig) {\n    this.config = config;\n    this.logger = new FtpLogger();\n  }\n\n  async start(): Promise<boolean> {\n    try {\n      this.serverSocket = socket.constructTCPSocketServerInstance();\n      \n      if (this.serverSocket) {\n        this.serverSocket.on('connect', (data: socket.TCPSocketConnection) => {\n          this.handleNewConnection(data);\n        });\n\n        this.serverSocket.on('error', (error: Error) => {\n          this.logger.error(`Server error: ${error.message}`);\n        });\n\n        const address: socket.NetAddress = {\n          address: '0.0.0.0',\n          port: this.config.port\n        };\n        await this.serverSocket.listen(address);\n        \n        this.isRunning = true;\n        this.logger.info(`FTP Server started on port ${this.config.port}`);\n        return true;\n      } else {\n        this.logger.error('Failed to create server socket');\n        return false;\n      }\n    } catch (error) {\n      this.logger.error(`Failed to start server: ${error}`);\n      this.isRunning = false;\n      return false;\n    }\n  }\n\n  private handleNewConnection(clientSocket: socket.TCPSocketConnection) {\n    try {\n      this.logger.info('New client connection received');\n      const connection = new FtpConnection(clientSocket, this.config, this.logger);\n      this.connections.push(connection);\n      \n      connection.on('close', () => {\n        this.connections = this.connections.filter(conn => conn !== connection);\n        this.logger.info(`Client connection closed. Current connections: ${this.connections.length}`);\n      });\n\n      connection.start();\n    } catch (error) {\n      this.logger.error(`Error handling new connection: ${error}`);\n      try {\n        clientSocket.close();\n      } catch (closeError) {\n        // Ignore close error\n      }\n    }\n  }\n\n  async stop(): Promise<void> {\n    if (!this.isRunning) {\n      this.logger.warn('Attempting to stop server that is not running');\n      return;\n    }\n\n    this.isRunning = false;\n    this.logger.info('Stopping FTP Server...');\n\n    // Close all connections\n    this.logger.info(`Closing ${this.connections.length} active connections`);\n    for (let i = 0; i < this.connections.length; i++) {\n      const connection = this.connections[i];\n      try {\n        await connection.close();\n      } catch (error) {\n        this.logger.error(`Error closing connection: ${error}`);\n      }\n    }\n    this.connections = [];\n\n    // Close server socket\n    if (this.serverSocket) {\n      try {\n        await this.serverSocket.close();\n        this.serverSocket = null;\n        this.logger.info('Server socket closed');\n      } catch (error) {\n        this.logger.error(`Error closing server socket: ${error}`);\n      }\n    }\n\n    this.logger.info('FTP Server stopped');\n  }\n\n  getStatus(): ServerStatus {\n    return {\n      isRunning: this.isRunning,\n      port: this.config.port,\n      connectionCount: this.connections.length\n    };\n  }\n}\n\n=== Operation 2 Result (Text) ===\n// 配置接口\nexport interface FtpConfigOptions {\n  port?: number;\n  rootDirectory?: string;\n  maxConnections?: number;\n  user?: string;\n  password?: string;\n  allowAnonymous?: boolean;\n  serverIp?: string;\n}\n\nexport class FtpConfig {\n  readonly port: number;\n  readonly rootDirectory: string;\n  readonly maxConnections: number;\n  readonly user: string;\n  readonly password: string;\n  readonly allowAnonymous: boolean;\n  readonly serverIp: string;\n\n  constructor(options: FtpConfigOptions = {}) {\n    this.port = options.port || 2121;\n    this.rootDirectory = options.rootDirectory || '/';\n    this.maxConnections = options.maxConnections || 10;\n    this.user = options.user || 'anonymous';\n    this.password = options.password || '';\n    this.allowAnonymous = options.allowAnonymous !== undefined ? options.allowAnonymous : true;\n    this.serverIp = options.serverIp || '127.0.0.1';\n  }\n\n  // 验证用户凭据\n  validateCredentials(user: string, password: string): boolean {\n    if (this.allowAnonymous && user === 'anonymous') {\n      return true;\n    }\n    return user === this.user && password === this.password;\n  }\n}\n\n=== Operation 3 Result (Text) ===\nimport { FtpServer, ServerStatus } from './FtpServer';\nimport { FtpConfig } from './FtpConfig';\nimport { FtpLogger } from './FtpLogger';\n\nexport class FtpServerManager {\n  private static instance: FtpServerManager;\n  private server: FtpServer | null = null;\n  private config: FtpConfig;\n  private logger: FtpLogger;\n\n  private constructor() {\n    this.config = new FtpConfig();\n    this.logger = new FtpLogger();\n  }\n\n  public static getInstance(): FtpServerManager {\n    if (!FtpServerManager.instance) {\n      FtpServerManager.instance = new FtpServerManager();\n    }\n    return FtpServerManager.instance;\n  }\n\n  // 启动FTP服务器\n  async startServer(config?: Partial<FtpConfig>): Promise<boolean> {\n    try {\n      // 如果服务器已经在运行，先停止\n      if (this.server) {\n        await this.stopServer();\n      }\n\n      // 更新配置\n      if (config) {\n        console.info('[FTP] startServer: Received config.rootDirectory:', config.rootDirectory);\n        this.config = new FtpConfig({\n          port: config.port || this.config.port,\n          rootDirectory: config.rootDirectory || this.config.rootDirectory,\n          maxConnections: config.maxConnections || this.config.maxConnections,\n          user: config.user || this.config.user,\n          password: config.password || this.config.password,\n          allowAnonymous: config.allowAnonymous !== undefined ? config.allowAnonymous : this.config.allowAnonymous,\n          serverIp: config.serverIp || this.config.serverIp\n        });\n        console.info('[FTP] startServer: New config.rootDirectory:', this.config.rootDirectory);\n      }\n\n      // 创建并启动服务器\n      this.server = new FtpServer(this.config);\n      const result = await this.server.start();\n      \n      if (result) {\n        this.logger.info('FTP Server started successfully');\n      } else {\n        this.logger.error('Failed to start FTP Server');\n      }\n      \n      return result;\n    } catch (error) {\n      this.logger.error(`Error starting FTP Server: ${error}`);\n      return false;\n    }\n  }\n\n  // 停止FTP服务器\n  async stopServer(): Promise<void> {\n    try {\n      if (this.server) {\n        await this.server.stop();\n        this.server = null;\n        this.logger.info('FTP Server stopped successfully');\n      }\n    } catch (error) {\n      this.logger.error(`Error stopping FTP Server: ${error}`);\n    }\n  }\n\n  // 重启FTP服务器\n  async restartServer(): Promise<boolean> {\n    await this.stopServer();\n    return await this.startServer();\n  }\n\n  // 获取服务器状态\n  getServerStatus(): ServerStatus {\n    if (this.server) {\n      return this.server.getStatus();\n    }\n    return {\n      isRunning: false,\n      port: this.config.port,\n      connectionCount: 0\n    };\n  }\n\n  // 获取当前配置\n  getConfig(): FtpConfig {\n    return this.config;\n  }\n\n  // 更新配置\n  updateConfig(configUpdate: Partial<FtpConfig>): void {\n    this.config = new FtpConfig({\n      port: configUpdate.port || this.config.port,\n      rootDirectory: configUpdate.rootDirectory || this.config.rootDirectory,\n      maxConnections: configUpdate.maxConnections || this.config.maxConnections,\n      user: configUpdate.user || this.config.user,\n      password: configUpdate.password || this.config.password,\n      allowAnonymous: configUpdate.allowAnonymous !== undefined ? configUpdate.allowAnonymous : this.config.allowAnonymous\n    });\n  }\n\n  // 设置日志级别\n  setLogLevel(logLevel: 'debug' | 'info' | 'warn' | 'error'): void {\n    this.logger.setLogLevel(logLevel);\n  }\n}\n\n=== Operation 4 Result (Text) ===\nimport socket from '@ohos.net.socket';\nimport { FtpConfig } from './FtpConfig';\nimport { FtpLogger } from './FtpLogger';\nimport { FtpCommandHandler } from './FtpCommandHandler';\nimport { EventEmitter } from './EventEmitter';\n\n// 定义接口\nexport interface Address {\n  port: number;\n}\n\nexport interface ServerAddress {\n  port: number;\n}\n\n// 定义数据服务器类型\nexport type DataServer = socket.TCPSocketServer;\n\nexport class FtpConnection extends EventEmitter {\n  private clientSocket: socket.TCPSocketConnection;\n  private dataSocket: socket.TCPSocketConnection | null = null;\n  private config: FtpConfig;\n  private logger: FtpLogger;\n  private commandHandler: FtpCommandHandler;\n  private isAuthenticated: boolean = false;\n  private currentUser: string = '';\n  private currentDirectory: string = '/';\n  private isActive: boolean = true;\n\n  constructor(clientSocket: socket.TCPSocketConnection, config: FtpConfig, logger: FtpLogger) {\n    super();\n    this.clientSocket = clientSocket;\n    this.config = config;\n    this.logger = logger;\n    this.commandHandler = new FtpCommandHandler(this);\n  }\n\n  start(): void {\n    try {\n      this.sendResponse(220, 'FTP Server ready');\n      this.logger.info('FTP Server ready for commands');\n      \n      this.clientSocket.on('message', async (messageInfo: socket.SocketMessageInfo) => {\n        await this.handleData(messageInfo.message);\n      });\n\n      this.clientSocket.on('error', (error: Error) => {\n        this.logger.error(`Connection error: ${error.message}`);\n        this.close();\n      });\n\n      this.clientSocket.on('close', () => {\n        this.logger.info('Client connection closed');\n        this.close();\n      });\n    } catch (error) {\n      this.logger.error(`Error starting connection handling: ${error}`);\n      this.close();\n    }\n  }\n\n  private async handleData(data: ArrayBuffer): Promise<void> {\n    try {\n      const uint8Array = new Uint8Array(data);\n      let command = '';\n      for (let i = 0; i < uint8Array.length; i++) {\n        command += String.fromCharCode(uint8Array[i]);\n      }\n      command = command.trim();\n      this.logger.debug(`Received command: ${command}`);\n      await this.commandHandler.handleCommand(command);\n    } catch (error) {\n      this.logger.error(`Error handling command data: ${error}`);\n      this.sendResponse(500, 'Internal server error');\n    }\n  }\n\n  sendResponse(code: number, message: string): void {\n    try {\n      const response = `${code} ${message}\\r\\n`;\n      this.logger.debug(`Sending response: ${response.trim()}`);\n      this.clientSocket.send({ data: response });\n    } catch (error) {\n      this.logger.error(`Error sending response: ${error}`);\n      // If we can't send a response, the connection is probably broken\n      this.close();\n    }\n  }\n\n  // 用于发送多行响应的中间行（不带状态码，以空格开头）\n  sendResponseLine(message: string): void {\n    try {\n      this.clientSocket.send({ data: ` ${message}\\r\\n` });\n    } catch (error) {\n      this.logger.error(`Error sending response line: ${error}`);\n    }\n  }\n\n  async sendData(data: string | ArrayBuffer): Promise<void> {\n    if (this.dataSocket) {\n      try {\n        await this.dataSocket.send({ data: data });\n      } catch (error) {\n        this.logger.error(`Error sending data: ${error}`);\n       // throw error;\n      }\n    } else {\n      throw new Error('No data socket available');\n    }\n  }\n\n  private dataPort: number = 0;\n  private dataServer: DataServer | null = null;\n  private activeModeAddress: string = '';\n  private activeModePort: number = 0;\n  private passiveAddress: string = '';\n  private static nextPassivePort: number = 50000;\n\n  async openDataConnection(): Promise<socket.TCPSocketConnection | null> {\n    try {\n      // 如果已经有数据服务器在监听，直接返回\n      if (this.dataServer && !this.dataSocket) {\n        return null; // 服务器已就绪，等待客户端连接\n      }\n      \n      // 关闭之前的数据服务器\n      if (this.dataServer) {\n        await this.closeDataServer();\n      }\n      \n      // 创建新的数据服务器\n      this.dataServer = socket.constructTCPSocketServerInstance();\n      this.dataSocket = null;\n      \n      // 使用下一个可用端口（动态分配）- 范围 50000-60000\n      FtpConnection.nextPassivePort++;\n      if (FtpConnection.nextPassivePort > 60000) {\n        FtpConnection.nextPassivePort = 50000;\n      }\n      this.dataPort = FtpConnection.nextPassivePort;\n      \n      return new Promise<socket.TCPSocketConnection | null>((resolve) => {\n        if (this.dataServer) {\n          this.dataServer.on('connect', (data: socket.TCPSocketConnection) => {\n            this.dataSocket = data;\n            resolve(data);\n          });\n\n          this.dataServer.on('error', (error: Error) => {\n            this.logger.error(`Data server error: ${error.message}`);\n            resolve(null);\n          });\n\n          // 绑定到端口\n          const address: socket.NetAddress = {\n            address: '0.0.0.0',\n            port: this.dataPort\n          };\n          \n          this.dataServer.listen(address).then(() => {\n            this.passiveAddress = '0.0.0.0';\n            this.logger.debug(`Data server started on port ${this.dataPort}`);\n            // 监听成功后立即返回null，表示服务器已就绪\n            resolve(null);\n          }).catch((error: Error) => {\n            this.logger.error(`Failed to start data server: ${error.message}`);\n            resolve(null);\n          });\n        } else {\n          resolve(null);\n        }\n      });\n    } catch (error) {\n      this.logger.error(`Failed to open data connection: ${error}`);\n      return null;\n    }\n  }\n\n  setActiveModeAddress(address: string, port: number): void {\n    this.activeModeAddress = address;\n    this.activeModePort = port;\n  }\n\n  getPassiveModePort(): number {\n    return this.dataPort;\n  }\n\n  getPassiveModeAddress(): string {\n    return this.passiveAddress;\n  }\n\n  // 等待客户端连接到数据服务器\n  async waitForDataConnection(timeoutMs: number = 30000): Promise<socket.TCPSocketConnection | null> {\n    const startTime = Date.now();\n    \n    while (!this.dataSocket) {\n      if (Date.now() - startTime > timeoutMs) {\n        this.logger.error('Data connection timeout');\n        return null;\n      }\n      // 等待一小段时间\n      await new Promise<void>((resolve) => {\n        setTimeout(() => resolve(), 100);\n      });\n    }\n    \n    return this.dataSocket;\n  }\n\n  async closeDataServer(): Promise<void> {\n    if (this.dataServer) {\n      try {\n        await this.dataServer.close();\n      } catch (error) {\n        this.logger.error(`Error closing data server: ${error}`);\n      }\n      this.dataServer = null;\n    }\n  }\n\n  async closeDataConnection(): Promise<void> {\n    if (this.dataSocket) {\n      try {\n        await this.dataSocket.close();\n      } catch (error) {\n        this.logger.error(`Error closing data socket: ${error}`);\n      }\n      this.dataSocket = null;\n    }\n    await this.closeDataServer();\n  }\n\n  async close(): Promise<void> {\n    if (!this.isActive) {\n      this.logger.debug('Attempting to close already closed connection');\n      return;\n    }\n\n    this.isActive = false;\n    this.logger.info('Closing FTP connection...');\n\n    // Close data connection first\n    try {\n      await this.closeDataConnection();\n    } catch (error) {\n      this.logger.error(`Error closing data connection: ${error}`);\n    }\n    \n    // Close control connection\n    try {\n      await this.clientSocket.close();\n      this.logger.info('Control connection closed');\n    } catch (error) {\n      this.logger.error(`Error closing control connection: ${error}`);\n    }\n\n    this.emit('close');\n    this.logger.info('FTP connection closed completely');\n  }\n\n  // Getters and setters\n  getConfig(): FtpConfig {\n    return this.config;\n  }\n\n  getLogger(): FtpLogger {\n    return this.logger;\n  }\n\n  isUserAuthenticated(): boolean {\n    return this.isAuthenticated;\n  }\n\n  setAuthenticated(authenticated: boolean): void {\n    this.isAuthenticated = authenticated;\n  }\n\n  setCurrentUser(user: string): void {\n    this.currentUser = user;\n  }\n\n  getCurrentUser(): string {\n    return this.currentUser;\n  }\n\n  getCurrentDirectory(): string {\n    return this.currentDirectory;\n  }\n\n  setCurrentDirectory(directory: string): void {\n    this.currentDirectory = directory;\n  }\n\n  isConnectionActive(): boolean {\n    return this.isActive;\n  }\n}\n\n=== Operation 5 Result (Text) ===\nimport { FtpConnection } from './FtpConnection';\nimport { FtpFileSystem } from './FtpFileSystem';\nimport net from '@ohos.net.socket';\nimport socket from '@ohos.net.socket';\nimport { fileIo } from '@kit.CoreFileKit'\n\nexport class FtpCommandHandler {\n  private connection: FtpConnection;\n  private fileSystem: FtpFileSystem;\n\n  constructor(connection: FtpConnection) {\n    this.connection = connection;\n    this.fileSystem = new FtpFileSystem(connection);\n  }\n\n  async handleCommand(command: string): Promise<void> {\n    const commandParts = command.split(' ');\n    const cmd = commandParts[0];\n    const args = commandParts.slice(1);\n    const commandName = cmd.toUpperCase();\n    const commandArgs = args.join(' ');\n\n    try {\n      switch (commandName) {\n        case 'USER':\n          this.handleUSER(commandArgs);\n          break;\n        case 'PASS':\n          this.handlePASS(commandArgs);\n          break;\n        case 'LIST':\n          await this.handleLIST(commandArgs);\n          break;\n        case 'NLST':\n          await this.handleNLST(commandArgs);\n          break;\n        case 'RETR':\n          await this.handleRETR(commandArgs);\n          break;\n        case 'STOR':\n          await this.handleSTOR(commandArgs);\n          break;\n        case 'DELE':\n          await this.handleDELE(commandArgs);\n          break;\n        case 'MKD':\n          await this.handleMKD(commandArgs);\n          break;\n        case 'RMD':\n          await this.handleRMD(commandArgs);\n          break;\n        case 'CWD':\n          this.handleCWD(commandArgs);\n          break;\n        case 'PWD':\n          this.handlePWD();\n          break;\n        case 'CDUP':\n          this.handleCDUP();\n          break;\n        case 'TYPE':\n          this.handleTYPE(commandArgs);\n          break;\n        case 'PORT':\n          this.handlePORT(commandArgs);\n          break;\n        case 'PASV':\n          this.handlePASV();\n          break;\n        case 'QUIT':\n          this.handleQUIT();\n          break;\n        case 'SYST':\n          this.handleSYST();\n          break;\n        case 'FEAT':\n          this.handleFEAT();\n          break;\n        default:\n          this.connection.sendResponse(502, 'Command not implemented');\n      }\n    } catch (error) {\n      this.connection.sendResponse(500, 'Internal server error');\n    }\n  }\n\n  private handleUSER(username: string): void {\n    this.connection.setCurrentUser(username);\n    this.connection.sendResponse(331, 'User name okay, need password');\n  }\n\n  private handlePASS(password: string): void {\n    const config = this.connection.getConfig();\n    if (config.validateCredentials(this.connection.getCurrentUser(), password)) {\n      this.connection.setAuthenticated(true);\n      this.connection.sendResponse(230, 'User logged in, proceed');\n    } else {\n      this.connection.sendResponse(530, 'User not logged in');\n    }\n  }\n\n  private async handleLIST(path: string): Promise<void> {\n    if (!this.connection.isUserAuthenticated()) {\n      this.connection.sendResponse(530, 'User not logged in');\n      return;\n    }\n\n    try {\n      // 先启动数据服务器监听\n      await this.connection.openDataConnection();\n\n      this.connection.sendResponse(150, 'Opening ASCII mode data connection for file list');\n      \n      // 等待客户端连接到数据服务器\n      const dataSocket = await this.connection.waitForDataConnection();\n      if (!dataSocket) {\n          this.connection.sendResponse(425, 'Can\\'t open data connection');\n        return;\n      }\n\n      const fileList = await this.fileSystem.listFiles(path || this.connection.getCurrentDirectory());\n      \n      // 发送文件列表数据\n      await this.connection.sendData(fileList);\n      await this.connection.closeDataConnection();\n      \n      this.connection.sendResponse(226, 'Transfer complete');\n    } catch (error) {\n      console.error('Error handling LIST command:', error);\n      this.connection.sendResponse(550, 'Failed to list files');\n    }\n  }\n\n  private async handleNLST(path: string): Promise<void> {\n    if (!this.connection.isUserAuthenticated()) {\n      this.connection.sendResponse(530, 'User not logged in');\n      return;\n    }\n\n    try {\n      // 先启动数据服务器监听\n      await this.connection.openDataConnection();\n      \n      this.connection.sendResponse(150, 'Opening ASCII mode data connection for file list');\n      \n      // 等待客户端连接到数据服务器\n      const dataSocket = await this.connection.waitForDataConnection();\n      if (!dataSocket) {\n        this.connection.sendResponse(425, 'Can\\'t open data connection');\n        return;\n      }\n      \n      const fileList = await this.fileSystem.listFileNames(path || this.connection.getCurrentDirectory());\n      \n      // 发送文件列表数据\n      await this.connection.sendData(fileList);\n      await this.connection.closeDataConnection();\n      \n      this.connection.sendResponse(226, 'Transfer complete');\n    } catch (error) {\n      console.error('Error handling NLST command:', error);\n      this.connection.sendResponse(550, 'Failed to list files');\n    }\n  }\n\n  private async handleRETR(filename: string): Promise<void> {\n    if (!this.connection.isUserAuthenticated()) {\n      this.connection.sendResponse(530, 'User not logged in');\n      return;\n    }\n\n    try {\n      // 先启动数据服务器监听\n      await this.connection.openDataConnection();\n      \n      this.connection.sendResponse(150, 'Opening BINARY mode data connection for file transfer');\n      \n      // 等待客户端连接到数据服务器\n      const dataSocket = await this.connection.waitForDataConnection();\n      if (!dataSocket) {\n        this.connection.sendResponse(425, 'Can\\'t open data connection');\n        return;\n      }\n      \n      const filePath = `${this.connection.getCurrentDirectory()}/${filename}`;\n      const fileData = await this.fileSystem.readFile(filePath);\n      await this.connection.sendData(fileData);\n      await this.connection.closeDataConnection();\n      \n      this.connection.sendResponse(226, 'Transfer complete');\n    } catch (error) {\n      console.error('Error handling RETR command:', error);\n      this.connection.sendResponse(550, 'Failed to retrieve file');\n    }\n  }\n\n  private async handleSTOR(filename: string): Promise<void> {\n    if (!this.connection.isUserAuthenticated()) {\n      this.connection.sendResponse(530, 'User not logged in');\n      return;\n    }\n\n    try {\n      // 先启动数据服务器监听\n      console.info('[FTP] STOR: Opening data connection for file:', filename);\n      await this.connection.openDataConnection();\n      \n      this.connection.sendResponse(150, 'Opening BINARY mode data connection for file transfer');\n      \n      // 等待客户端连接到数据服务器\n      const dataSocket = await this.connection.waitForDataConnection();\n      if (!dataSocket) {\n        console.error('[FTP] STOR: Data connection timeout');\n        this.connection.sendResponse(425, 'Can\\'t open data connection');\n        return;\n      }\n      \n      console.info('[FTP] STOR: Data connection established, reading file data...');\n      // 实现从数据连接读取文件数据的逻辑\n      const fileData = await this.readDataFromSocket(dataSocket);\n      \n      console.info('[FTP] STOR: Received', fileData.byteLength, 'bytes, writing to:', filename);\n\n      // 将读取的数据写入文件\n      const filePath = `${this.connection.getCurrentDirectory()}/${filename}`;\n      console.info('[FTP] STOR: Full path:', filePath);\n      await this.fileSystem.writeFile(filePath, fileData);\n\n      await this.connection.closeDataConnection();\n\n      this.connection.sendResponse(226, 'Transfer complete');\n      console.info('[FTP] STOR: File stored successfully');\n    } catch (error) {\n      console.error('[FTP] STOR error:', error);\n      this.connection.sendResponse(550, 'Failed to store file');\n    }\n  }\n\n  // 从数据连接读取文件数据\n  private async readDataFromSocket(dataSocket: socket.TCPSocketConnection): Promise<ArrayBuffer> {\n    return new Promise<ArrayBuffer>((resolve, reject) => {\n      let dataChunks: ArrayBuffer[] = [];\n      let totalSize = 0;\n      \n      // 设置超时 - 30秒\n      const timeoutId = setTimeout(() => {\n        console.error('[FTP] readDataFromSocket: Timeout waiting for data');\n        // 即使超时也返回已接收的数据\n        if (dataChunks.length > 0) {\n          const result = new ArrayBuffer(totalSize);\n          const resultView = new Uint8Array(result);\n          let offset = 0;\n          for (const chunk of dataChunks) {\n            const chunkView = new Uint8Array(chunk);\n            resultView.set(chunkView, offset);\n            offset += chunk.byteLength;\n          }\n          console.info('[FTP] readDataFromSocket: Timeout but returning', totalSize, 'bytes');\n          resolve(result);\n        } else {\n          reject(new Error('Timeout waiting for data'));\n        }\n      }, 30000);\n\n      // 监听消息\n      dataSocket.on('message', (messageInfo: socket.SocketMessageInfo) => {\n        try {\n          const data = messageInfo.message;\n          if (data && data.byteLength > 0) {\n            dataChunks.push(data);\n            totalSize += data.byteLength;\n            console.info('[FTP] readDataFromSocket: Received chunk,', data.byteLength, 'bytes, total:', totalSize);\n          }\n        } catch (error) {\n          console.error('[FTP] Error receiving data:', error);\n          clearTimeout(timeoutId);\n          reject(new Error('Failed to receive data'));\n        }\n      });\n\n      // 监听连接关闭\n      dataSocket.on('close', () => {\n        clearTimeout(timeoutId);\n        console.info('[FTP] readDataFromSocket: Connection closed, total received:', totalSize);\n        try {\n          // 合并所有数据块\n          if (totalSize === 0) {\n            resolve(new ArrayBuffer(0));\n            return;\n          }\n          const result = new ArrayBuffer(totalSize);\n          const resultView = new Uint8Array(result);\n          let offset = 0;\n\n          for (const chunk of dataChunks) {\n            const chunkView = new Uint8Array(chunk);\n            resultView.set(chunkView, offset);\n            offset += chunk.byteLength;\n          }\n\n          resolve(result);\n        } catch (error) {\n          console.error('[FTP] Error processing received data:', error);\n          reject(new Error('Failed to process received data'));\n        }\n      });\n\n      // 监听错误\n      dataSocket.on('error', (error: Error) => {\n        clearTimeout(timeoutId);\n        console.error('[FTP] Socket error:', error);\n        reject(new Error('Socket error during data transfer'));\n      });\n    });\n  }\n\n  private async handleDELE(filename: string): Promise<void> {\n    if (!this.connection.isUserAuthenticated()) {\n      this.connection.sendResponse(530, 'User not logged in');\n      return;\n    }\n\n    try {\n      const filePath = `${this.connection.getCurrentDirectory()}/${filename}`;\n      await this.fileSystem.deleteFile(filePath);\n      this.connection.sendResponse(250, 'Requested file action okay, completed');\n    } catch (error) {\n      this.connection.sendResponse(550, 'Failed to delete file');\n    }\n  }\n\n  private async handleMKD(directory: string): Promise<void> {\n    if (!this.connection.isUserAuthenticated()) {\n      this.connection.sendResponse(530, 'User not logged in');\n      return;\n    }\n\n    try {\n      const dirPath = `${this.connection.getCurrentDirectory()}/${directory}`;\n      await this.fileSystem.createDirectory(dirPath);\n      this.connection.sendResponse(257, `\"${dirPath}\" created`);\n    } catch (error) {\n      this.connection.sendResponse(550, 'Failed to create directory');\n    }\n  }\n\n  private async handleRMD(directory: string): Promise<void> {\n    if (!this.connection.isUserAuthenticated()) {\n      this.connection.sendResponse(530, 'User not logged in');\n      return;\n    }\n\n    try {\n      const dirPath = `${this.connection.getCurrentDirectory()}/${directory}`;\n      await this.fileSystem.deleteDirectory(dirPath);\n      this.connection.sendResponse(250, 'Requested file action okay, completed');\n    } catch (error) {\n      this.connection.sendResponse(550, 'Failed to delete directory');\n    }\n  }\n\n  private handleCWD(path: string): void {\n    if (!this.connection.isUserAuthenticated()) {\n      this.connection.sendResponse(530, 'User not logged in');\n      return;\n    }\n\n    // 实现切换目录逻辑\n    this.connection.setCurrentDirectory(path);\n    this.connection.sendResponse(250, 'Requested file action okay, completed');\n  }\n\n  private handlePWD(): void {\n    if (!this.connection.isUserAuthenticated()) {\n      this.connection.sendResponse(530, 'User not logged in');\n      return;\n    }\n\n    this.connection.sendResponse(257, `\"${this.connection.getCurrentDirectory()}\" is the current directory`);\n  }\n\n  private handleCDUP(): void {\n    if (!this.connection.isUserAuthenticated()) {\n      this.connection.sendResponse(530, 'User not logged in');\n      return;\n    }\n\n    // 实现切换到父目录逻辑\n    const currentDir = this.connection.getCurrentDirectory();\n    if (currentDir !== '/') {\n      const parentDir = currentDir.substring(0, currentDir.lastIndexOf('/')) || '/';\n      this.connection.setCurrentDirectory(parentDir);\n    }\n    this.connection.sendResponse(250, 'Requested file action okay, completed');\n  }\n\n  private handleTYPE(type: string): void {\n    // 实现设置传输类型逻辑\n    this.connection.sendResponse(200, 'Command okay');\n  }\n\n  private handlePORT(port: string): void {\n    // 实现主动模式端口设置逻辑\n    try {\n      const parts = port.split(',');\n      if (parts.length === 6) {\n        const ip = parts.slice(0, 4).join('.');\n        const p1 = parseInt(parts[4], 10);\n        const p2 = parseInt(parts[5], 10);\n        const portNumber = p1 * 256 + p2;\n        \n        this.connection.setActiveModeAddress(ip, portNumber);\n        this.connection.sendResponse(200, 'Command okay');\n      } else {\n        this.connection.sendResponse(501, 'Syntax error in parameters or arguments');\n      }\n    } catch (error) {\n      this.connection.sendResponse(501, 'Syntax error in parameters or arguments');\n    }\n  }\n\n  private handlePASV(): void {\n    // 实现被动模式逻辑\n    // 打开数据连接获取实际端口\n    console.info('[FTP] PASV command received, opening data connection...');\n    this.connection.openDataConnection().then((dataSocket) => {\n      // 监听成功后，服务器已就绪，等待客户端连接数据端口\n      const port = this.connection.getPassiveModePort();\n      console.info('[FTP] PASV data server started on port:', port);\n      // 从配置中获取服务器IP地址\n      const config = this.connection.getConfig();\n      //const serverIp = config.serverIp || '127.0.0.1';\n      const serverIp =  '127.0.0.1';\n      // 将IP地址转换为逗号分隔格式\n      const ipParts = serverIp.split('.');\n      const ip = ipParts.join(',');\n      \n      // 将端口转换为两个字节\n      const p1 = Math.floor(port / 256);\n      const p2 = port % 256;\n      \n      console.info('[FTP] Sending PASV response with port:', port, 'p1:', p1, 'p2:', p2);\n      this.connection.sendResponse(227, `Entering Passive Mode (${ip},${p1},${p2})`);\n    }).catch(() => {\n      this.connection.sendResponse(425, 'Can\\'t open data connection');\n    });\n  }\n\n  private handleQUIT(): void {\n    this.connection.sendResponse(221, 'Service closing control connection');\n    this.connection.close();\n  }\n\n  private handleSYST(): void {\n    this.connection.sendResponse(215, 'UNIX Type: L8');\n  }\n\n  private handleFEAT(): void {\n    // FTP多行响应格式：211-Features 然后是特性列表 最后以211 End结束\n    this.connection.sendResponse(211, 'Features:');\n    this.connection.sendResponseLine(' SIZE');\n    this.connection.sendResponseLine(' UTF8');\n    this.connection.sendResponse(211, 'End');\n  }\n}\n\n=== Operation 6 Result (Text) ===\nimport fs from '@ohos.file.fs';\nimport { FtpConnection } from './FtpConnection';\nimport common from '@ohos.app.ability.common';\nimport { fileIo } from '@kit.CoreFileKit'\nimport featureAbility from '@ohos.ability.featureAbility';\n\n// 接口定义\nexport interface FileEntry {\n  name: string;\n  path: string;\n}\n\nexport interface FileInfo {\n  name: string;\n  size: number;\n  modifiedTime: Date;\n  type: 'file' | 'directory';\n}\n\nexport class FtpFileSystem {\n  private connection: FtpConnection;\n  private rootPath: string;\n\n  constructor(connection: FtpConnection) {\n    this.connection = connection;\n    // 从配置中获取FTP根目录\n    const config = connection.getConfig();\n    this.rootPath = config.rootDirectory;\n    console.info('[FTP] FtpFileSystem constructor: rootDirectory from config:', this.rootPath);\n    \n    // 如果配置目录为空或不可访问，使用默认目录\n    if (!this.rootPath || this.rootPath === '/') {\n      try {\n        const context = getContext();\n        this.rootPath = context.filesDir;\n        console.info('[FTP] Using default filesDir:', this.rootPath);\n      } catch (e) {\n        this.rootPath = '/';\n      }\n    }\n  }\n\n  async listFiles(path: string): Promise<string> {\n    try {\n      const fullPath = this.getFullPath(path);\n\n      // 先打开目录获取文件描述符\n      const files = await this.getFilesInDirectory(fullPath);\n      console.info('[FTP] listFiles: got', files.length, 'files');\n\n      let result = '';\n      \n      for (const file of files) {\n        const fileInfo = await this.getFileInfo(file);\n        result += `${fileInfo.type === 'directory' ? 'd' : '-'}rwxrwxrwx 1 ftp ftp ${fileInfo.size} ${this.formatDate(fileInfo.modifiedTime)} ${fileInfo.name}\\r\\n`;\n      }\n      \n      return result;\n    } catch (error) {\n      console.error('[FTP] listFiles error:', error);\n      throw new Error('Failed to list files');\n    }\n  }\n\n  async listFileNames(path: string): Promise<string> {\n    try {\n      const fullPath = this.getFullPath(path);\n      const files = await this.getFilesInDirectory(fullPath);\n      return files.map(file => file.name).join('\\r\\n') + '\\r\\n';\n    } catch (error) {\n      throw new Error('Failed to list file names');\n    }\n  }\n\n  async getFilesInDirectory(path: string): Promise<FileEntry[]> {\n    console.info('[FTP] getFilesInDirectory: Listing files in:', path);\n    try {\n      // 先检查目录是否存在\n      try {\n        const dirStat = await fs.stat(path);\n        console.info('[FTP] getFilesInDirectory: Directory exists, isDirectory:', dirStat.isDirectory());\n      } catch (statError) {\n        console.error('[FTP] getFilesInDirectory: Directory does not exist or not accessible:', statError);\n      }\n      \n      // 使用listFile列出文件\n      const entries: string[] = await fs.listFile(path);\n      console.info('[FTP] getFilesInDirectory: Found', entries.length, 'entries');\n      \n      const result: FileEntry[] = [];\n      for (let i = 0; i < entries.length; i++) {\n        const entryName: string = entries[i];\n        const entryPath = `${path}/${entryName}`;\n        \n        // 检查是文件还是目录\n        try {\n          const stat = await fs.stat(entryPath);\n          console.info('[FTP] getFilesInDirectory: Entry:', entryName, 'isDirectory:', stat.isDirectory());\n        } catch (entryStatError) {\n          console.error('[FTP] getFilesInDirectory: Cannot stat entry:', entryName, entryStatError);\n        }\n        \n        result.push({\n          name: entryName,\n          path: entryPath\n        });\n      }\n      return result;\n    } catch (error) {\n      console.error('[FTP] getFilesInDirectory error:', error);\n      // 如果目录不存在，返回空数组\n      return [];\n    }\n  }\n\n  async getFileInfo(file: FileEntry): Promise<FileInfo> {\n    try {\n      const stat = await fs.stat(file.path);\n      return {\n        name: file.name,\n        size: stat.size,\n        modifiedTime: new Date(stat.mtime),\n        type: stat.isDirectory() ? 'directory' : 'file'\n      };\n    } catch (error) {\n      // 如果获取文件信息失败，返回默认值\n      return {\n        name: file.name,\n        size: 0,\n        modifiedTime: new Date(),\n        type: 'file'\n      };\n    }\n  }\n\n  private formatDate(date: Date): string {\n    const month = date.toLocaleString('default', { month: 'short' });\n    const day = date.getDate().toString().padStart(2, ' ');\n    const hours = date.getHours().toString().padStart(2, '0');\n    const minutes = date.getMinutes().toString().padStart(2, '0');\n    \n    return `${month} ${day} ${hours}:${minutes}`;\n  }\n\n  async readFile(path: string): Promise<ArrayBuffer> {\n    try {\n      const fullPath = this.getFullPath(path);\n      const file = await fs.open(fullPath, fs.OpenMode.READ_ONLY);\n      const size = (await fs.stat(fullPath)).size;\n      const buffer = new ArrayBuffer(size);\n      await fs.read(file.fd, buffer);\n      await fs.close(file.fd);\n      return buffer;\n    } catch (error) {\n      throw new Error('Failed to read file');\n    }\n  }\n\n  async writeFile(path: string, data: ArrayBuffer): Promise<void> {\n    try {\n      const fullPath = this.getFullPath(path);\n      console.info('[FTP] writeFile: Writing to fullPath:', fullPath, 'size:', data.byteLength);\n      // 确保目录存在\n      await this.ensureDirectoryExists(fullPath.substring(0, fullPath.lastIndexOf('/')));\n      const file = await fs.open(fullPath, fs.OpenMode.CREATE | fs.OpenMode.WRITE_ONLY);\n      await fs.write(file.fd, data);\n      await fs.close(file.fd);\n      console.info('[FTP] writeFile: Success');\n    } catch (error) {\n      console.error('[FTP] writeFile error:', error);\n      throw new Error('Failed to write file');\n    }\n  }\n\n  async deleteFile(path: string): Promise<void> {\n    try {\n      const fullPath = this.getFullPath(path);\n      await fs.unlink(fullPath);\n    } catch (error) {\n      throw new Error('Failed to delete file');\n    }\n  }\n\n  async createDirectory(path: string): Promise<void> {\n    try {\n      const fullPath = this.getFullPath(path);\n      // 使用递归方式创建目录\n      await this.createDirectoryRecursive(fullPath);\n    } catch (error) {\n      throw new Error('Failed to create directory');\n    }\n  }\n\n  async deleteDirectory(path: string): Promise<void> {\n    try {\n      const fullPath = this.getFullPath(path);\n      await this.rmdirRecursive(fullPath);\n    } catch (error) {\n      throw new Error('Failed to delete directory');\n    }\n  }\n\n  async exists(path: string): Promise<boolean> {\n    try {\n      const fullPath = this.getFullPath(path);\n      await fs.stat(fullPath);\n      return true;\n    } catch (error) {\n      return false;\n    }\n  }\n\n  async isDirectory(path: string): Promise<boolean> {\n    try {\n      const fullPath = this.getFullPath(path);\n      const stat = await fs.stat(fullPath);\n      return stat.isDirectory();\n    } catch (error) {\n      return false;\n    }\n  }\n\n  private getFullPath(relativePath: string): string {\n    // 处理相对路径，确保使用应用沙箱路径作为根目录\n    if (relativePath === '/') {\n      return this.rootPath;\n    }\n    // 移除开头的斜杠\n    const normalizedPath = relativePath.startsWith('/') ? relativePath.substring(1) : relativePath;\n    return `${this.rootPath}/${normalizedPath}`;\n  }\n\n  private async ensureDirectoryExists(directory: string): Promise<void> {\n    try {\n      await fs.stat(directory);\n    } catch (error) {\n      // 目录不存在，创建它\n      try {\n        await this.createDirectoryRecursive(directory);\n      } catch (mkdirError) {\n        throw new Error('Failed to create directory');\n      }\n    }\n  }\n\n  private async createDirectoryRecursive(path: string): Promise<void> {\n    const parts = path.split('/');\n    let currentPath = '';\n    \n    for (const part of parts) {\n      if (part) {\n        currentPath += '/' + part;\n        try {\n          await fs.stat(currentPath);\n        } catch (error) {\n          await fs.mkdir(currentPath);\n        }\n      }\n    }\n  }\n\n  private async rmdirRecursive(path: string): Promise<void> {\n    try {\n      const entries: string[] = await fs.listFile(path);\n      for (let i = 0; i < entries.length; i++) {\n        const entryName: string = entries[i];\n        const entryPath = `${path}/${entryName}`;\n        try {\n          const stat = await fs.stat(entryPath);\n          if (stat.isDirectory()) {\n            await this.rmdirRecursive(entryPath);\n          } else {\n            await fs.unlink(entryPath);\n          }\n        } catch (entryError) {\n          // 忽略单个文件/目录的错误，继续处理其他项\n        }\n      }\n      await fs.rmdir(path);\n    } catch (error) {\n      throw new Error('Failed to delete directory recursively');\n    }\n  }\n}\n\n=== Operation 7 Result (Text) ===\nexport class FtpLogger {\n  private logLevel: 'debug' | 'info' | 'warn' | 'error' = 'info';\n\n  setLogLevel(level: 'debug' | 'info' | 'warn' | 'error'): void {\n    this.logLevel = level;\n  }\n\n  debug(message: string): void {\n    if (this.logLevel === 'debug') {\n      console.debug(`[FTP DEBUG] ${new Date().toISOString()} - ${message}`);\n    }\n  }\n\n  info(message: string): void {\n    if (['debug', 'info'].includes(this.logLevel)) {\n      console.info(`[FTP INFO] ${new Date().toISOString()} - ${message}`);\n    }\n  }\n\n  warn(message: string): void {\n    if (['debug', 'info', 'warn'].includes(this.logLevel)) {\n      console.warn(`[FTP WARN] ${new Date().toISOString()} - ${message}`);\n    }\n  }\n\n  error(message: string): void {\n    console.error(`[FTP ERROR] ${new Date().toISOString()} - ${message}`);\n  }\n}\n\n=== Operation 8 Result (Text) ===\nexport class EventEmitter {\n  private events: Map<string, Function[]> = new Map();\n\n  on(event: string, listener: Function): void {\n    if (!this.events.has(event)) {\n      this.events.set(event, []);\n    }\n    this.events.get(event)!.push(listener);\n  }\n  emit(event: string, ...args: unknown[]): void {\n    const listeners = this.events.get(event);\n    if (listeners) {\n      listeners.forEach(listener => {\n        listener(...args);\n      });\n    }\n  }\n\n  off(event: string, listener: Function): void {\n    const listeners = this.events.get(event);\n    if (listeners) {\n      const index = listeners.indexOf(listener);\n      if (index !== -1) {\n        listeners.splice(index, 1);\n      }\n    }\n  }\n\n  removeAllListeners(event?: string): void {\n    if (event) {\n      this.events.delete(event);\n    } else {\n      this.events.clear();\n    }\n  }\n\n  listenerCount(event: string): number {\n    const listeners = this.events.get(event);\n    return listeners ? listeners.length : 0;\n  }\n}"
