                          "url": "https://networkengineering.stackexchange.com/questions/24269/network-byte-order",
                          "snippet": "According to big endian byte ordering or network byte order the bits are transmitted in this order: bits 0-7 first, then bits 8-15, then 16-23 and bits 24-31 last.",
                          "publishedDate": 1447162948000,
                          "id": "4",
                          "domain": "stackexchange.com",
                          "maxVerbatimWordLimit": -1,
                          "publicDomain": false
