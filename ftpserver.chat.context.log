              "args": {
                "command": "create",
                "file_text": "import { FtpServerManager } from '../ftp/FtpServerManager';\nimport { FtpConfigOptions } from '../ftp/FtpConfig';\nimport { LogLevel } from '../ftp/FtpLogger';\nimport wifiManager from '@ohos.wifiManager';\n\n@Entry\n@Component\nstruct Index {\n  @State isRunning: boolean = false;\n  @State serverPort: string = '2121';\n  @State serverUser: string = 'admin';\n  @State serverPassword: string = '123456';\n  @State allowAnonymous: boolean = true;\n  @State rootDirectory: string = '';\n  @State connectionCount: number = 0;\n  @State statusMessage: string = 'FTP 服务器已停止';\n  @State isLoading: boolean = false;\n  @State deviceIp: string = '获取中...';\n  @State logs: string[] = [];\n\n  private manager = FtpServerManager.getInstance();\n  private updateTimer: number = -1;\n  private logScroller: Scroller = new Scroller();\n\n  aboutToAppear() {\n    this.manager.setLogLevel('debug');\n    this.manager.setLogCallback((level: LogLevel, msg: string) => {\n      const ts = new Date();\n      const time = `${ts.getHours().toString().padStart(2, '0')}:${ts.getMinutes().toString().padStart(2, '0')}:${ts.getSeconds().toString().padStart(2, '0')}`;\n      const tag = level.toUpperCase().padEnd(5, ' ');\n      this.logs.push(`[${time}] ${tag} ${msg}`);\n      // 保留最近200条\n      if (this.logs.length > 200) {\n        this.logs = this.logs.slice(-200);\n      }\n    });\n    this.getDeviceIp();\n    this.initRootDirectory();\n    this.startStatusTimer();\n  }\n\n  aboutToDisappear() {\n    this.stopStatusTimer();\n    this.manager.setLogCallback(null);\n  }\n\n  private initRootDirectory(): void {\n    try {\n      const ctx = getContext();\n      this.rootDirectory = ctx.filesDir;\n    } catch (e) {\n      this.rootDirectory = '/data/storage/el2/base/files';\n    }\n  }\n\n  private getDeviceIp(): void {\n    try {\n      if (wifiManager.isWifiActive()) {\n        const info = wifiManager.getIpInfo();\n        if (info && info.ipAddress) {\n          // HarmonyOS ipAddress 是小端序整数\n          const ip = info.ipAddress;\n          this.deviceIp = `${ip & 0xFF}.${(ip >> 8) & 0xFF}.${(ip >> 16) & 0xFF}.${(ip >> 24) & 0xFF}`;\n          return;\n        }\n      }\n      this.deviceIp = '未连接WiFi';\n    } catch (e) {\n      this.deviceIp = '获取失败';\n    }\n  }\n\n  private startStatusTimer(): void {\n    if (this.updateTimer !== -1) return;\n    this.updateTimer = setInterval(() => {\n      const s = this.manager.getServerStatus();\n      this.isRunning = s.isRunning;\n      this.connectionCount = s.connectionCount;\n    }, 2000);\n  }\n\n  private stopStatusTimer(): void {\n    if (this.updateTimer !== -1) {\n      clearInterval(this.updateTimer);\n      this.updateTimer = -1;\n    }\n  }\n\n  private async startServer(): Promise<void> {\n    if (this.isLoading) return;\n    this.isLoading = true;\n    this.statusMessage = '正在启动...';\n    this.logs = [];\n\n    try {\n      const port = parseInt(this.serverPort) || 2121;\n      const config: FtpConfigOptions = {\n        port: port,\n        user: this.serverUser,\n        password: this.serverPassword,\n        allowAnonymous: this.allowAnonymous,\n        rootDirectory: this.rootDirectory,\n        serverIp: this.deviceIp\n      };\n\n      const ok = await this.manager.startServer(config);\n      if (ok) {\n        this.isRunning = true;\n        this.statusMessage = `FTP 服务器运行中 - 端口 ${port}`;\n      } else {\n        this.statusMessage = '启动失败';\n      }\n    } catch (error) {\n      this.statusMessage = `启动出错: ${(error as Error).message}`;\n    } finally {\n      this.isLoading = false;\n    }\n  }\n\n  private async stopServer(): Promise<void> {\n    if (this.isLoading) return;\n    this.isLoading = true;\n    try {\n      await this.manager.stopServer();\n      this.isRunning = false;\n      this.connectionCount = 0;\n      this.statusMessage = 'FTP 服务器已停止';\n    } catch (error) {\n      this.statusMessage = `停止出错: ${(error as Error).message}`;\n    } finally {\n      this.isLoading = false;\n    }\n  }\n\n  build() {\n    Column() {\n      // 标题\n      Text('FTP Server')\n        .fontSize(28)\n        .fontWeight(FontWeight.Bold)\n        .margin({ top: 20, bottom: 10 })\n\n      // 状态卡片\n      Column({ space: 6 }) {\n        Row() {\n          Circle({ width: 12, height: 12 })\n            .fill(this.isRunning ? '#52C41A' : '#FF4D4F')\n          Text(this.statusMessage)\n            .fontSize(16)\n            .fontWeight(FontWeight.Medium)\n            .margin({ left: 8 })\n        }\n\n        Text(`IP: ${this.deviceIp}`)\n          .fontSize(14)\n          .fontColor('#666')\n\n        if (this.isRunning) {\n          Text(`ftp://${this.serverUser}:${this.serverPassword}@${this.deviceIp}:${this.serverPort}`)\n            .fontSize(13)\n            .fontColor('#1890FF')\n            .copyOption(CopyOptions.LocalDevice)\n\n          Text(`活跃连接: ${this.connectionCount}`)\n            .fontSize(14)\n            .fontColor('#666')\n        }\n      }\n      .width('92%')\n      .padding(16)\n      .backgroundColor(this.isRunning ? '#F6FFED' : '#FFF7E6')\n      .borderRadius(12)\n\n      // 启动/停止按钮\n      Row({ space: 16 }) {\n        Button(this.isRunning ? '停止服务器' : '启动服务器')\n          .width('60%')\n          .height(44)\n          .fontSize(16)\n          .backgroundColor(this.isRunning ? '#FF4D4F' : '#52C41A')\n          .fontColor('#FFF')\n          .borderRadius(8)\n          .enabled(!this.isLoading)\n          .onClick(() => {\n            if (this.isRunning) {\n              this.stopServer();\n            } else {\n              this.startServer();\n            }\n          })\n      }\n      .width('92%')\n      .margin({ top: 12 })\n      .justifyContent(FlexAlign.Center)\n\n      // 配置区域\n      Column({ space: 10 }) {\n        Text('服务器配置')\n          .fontSize(18)\n          .fontWeight(FontWeight.Bold)\n          .alignSelf(ItemAlign.Start)\n\n        this.configRow('端口', this.serverPort, (v: string) => { this.serverPort = v; })\n        this.configRow('用户名', this.serverUser, (v: string) => { this.serverUser = v; })\n        this.configRowPassword('密码', this.serverPassword, (v: string) => { this.serverPassword = v; })\n\n        Row() {\n          Text('根目录')\n            .width('25%')\n            .fontSize(14)\n          Text(this.rootDirectory)\n            .width('75%')\n            .fontSize(12)\n            .fontColor('#666')\n            .maxLines(2)\n            .textOverflow({ overflow: TextOverflow.Ellipsis })\n        }\n\n        Row() {\n          Text('允许匿名')\n            .fontSize(14)\n            .layoutWeight(1)\n          Toggle({ type: ToggleType.Switch, isOn: this.allowAnonymous })\n            .onChange((isOn: boolean) => { this.allowAnonymous = isOn; })\n        }\n      }\n      .width('92%')\n      .padding(14)\n      .backgroundColor('#F5F5F5')\n      .borderRadius(12)\n      .margin({ top: 12 })\n\n      // 日志区域\n      Column() {\n        Row() {\n          Text('运行日志')\n            .fontSize(16)\n            .fontWeight(FontWeight.Bold)\n            .layoutWeight(1)\n          Button('清除')\n            .fontSize(12)\n            .height(28)\n            .backgroundColor('#EEE')\n            .fontColor('#333')\n            .onClick(() => { this.logs = []; })\n        }\n        .width('100%')\n        .margin({ bottom: 6 })\n\n        Scroll(this.logScroller) {\n          Column() {\n            ForEach(this.logs, (log: string, index: number) => {\n              Text(log)\n                .fontSize(11)\n                .fontColor(log.includes('ERROR') ? '#FF4D4F' : (log.includes('WARN') ? '#FAAD14' : '#333'))\n                .fontFamily('monospace')\n                .width('100%')\n                .padding({ top: 1, bottom: 1 })\n            })\n          }\n          .width('100%')\n          .alignItems(HorizontalAlign.Start)\n        }\n        .layoutWeight(1)\n        .backgroundColor('#FAFAFA')\n        .borderRadius(6)\n        .padding(6)\n      }\n      .width('92%')\n      .layoutWeight(1)\n      .margin({ top: 12, bottom: 12 })\n    }\n    .width('100%')\n    .height('100%')\n    .backgroundColor('#FFF')\n  }\n\n  @Builder\n  configRow(label: string, value: string, onChange: (v: string) => void) {\n    Row() {\n      Text(label)\n        .width('25%')\n        .fontSize(14)\n      TextInput({ text: value })\n        .width('75%')\n        .height(36)\n        .fontSize(14)\n        .borderRadius(6)\n        .enabled(!this.isRunning)\n        .onChange(onChange)\n    }\n  }\n\n  @Builder\n  configRowPassword(label: string, value: string, onChange: (v: string) => void) {\n    Row() {\n      Text(label)\n        .width('25%')\n        .fontSize(14)\n      TextInput({ text: value })\n        .width('75%')\n        .height(36)\n        .fontSize(14)\n        .borderRadius(6)\n        .type(InputType.Password)\n        .enabled(!this.isRunning)\n        .onChange(onChange)\n    }\n  }\n}\n",
